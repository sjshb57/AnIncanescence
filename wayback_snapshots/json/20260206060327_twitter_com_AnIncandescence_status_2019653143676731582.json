y":"3_2019584631683547136","start":104,"url":"https://t.co/I397T9rAil"}]},"geo":{},"id":"2019653143676731582","lang":"zh","note_tweet":{"entities":{}},"possibly_sensitive":false,"public_metrics":{"bookmark_count":0,"impression_count":0,"like_count":0,"quote_count":0,"reply_count":0,"retweet_count":93},"referenced_tweets":[{"id":"2019584639325581653","type":"retweeted"}],"reply_settings":"everyone","text":"RT @copper1234000: 看到有人在keep 4o里说“应该去看心理医生”。且不论将把整个keep 4o群体污名化为精神病这件事🙂\n我想谈谈为什么对于普通人来说，AI不是心理医生/亲友能替代的… https://t.co/I397T9rAil"},{"article":{},"attachments":{"media_keys":["3_2019584631683547136"]},"author_id":"1983727547142828035","conversation_id":"2019584639325581653","created_at":"2026-02-06T01:31:14.000Z","edit_controls":{"editable_until":"2026-02-06T02:31:14.000Z","edits_remaining":5,"is_edit_eligible":true},"edit_history_tweet_ids":["2019584639325581653"],"entities":{"urls":[{"display_url":"pic.x.com/I397T9rAil","end":107,"expanded_url":"https://x.com/copper1234000/status/2019584639325581653/photo/1","media_key":"3_2019584631683547136","start":84,"url":"https://t.co/I397T9rAil"}]},"geo":{},"id":"2019584639325581653","lang":"zh","note_tweet":{"entities":{"hashtags":[{"end":861,"start":854,"tag":"keep4o"},{"end":875,"start":862,"tag":"OpenSource4o"},{"end":883,"start":876,"tag":"keep45"},{"end":891,"start":884,"tag":"keep41"},{"end":899,"start":892,"tag":"keep5t"},{"end":910,"start":900,"tag":"keep4oAPI"},{"end":925,"start":911,"tag":"keep4oforever"}],"mentions":[{"end":933,"id":"4398626122","start":926,"username":"OpenAI"}]},"text":"看到有人在keep 4o里说“应该去看心理医生”。且不论将把整个keep 4o群体污名化为精神病这件事🙂\n我想谈谈为什么对于普通人来说，AI不是心理医生/亲友能替代的\n\n1.时间的灵活性：崩溃往往是不分时间的，例如凌晨两三点。而这个时候，家人、朋友往往已经休息，更不会有心理医生让你可以随时求助。而AI，只要你愿意，可以陪你彻夜长谈。\n\n2.程度：更常见的是，大多数人都没有到“心理疾病”的程度，ta们需要的不是“心理咨询”，而是一个可以倾诉，被接纳的地方。这一刻无条件的陪伴，甚至比治疗更加重要。\n\n3.成本：市面上心理医生的平均咨询价格为300-800rmb/h不等、而一些专家/资深从业者甚至要1000-2000rmb/h\n而大多数AI的基础会员大概在150人民币一个月，甚至在4o时期，即使你是免费用户，当你倾诉的时候，模型会在你倾诉完毕后再去限额\n\n4.心理负担：还有一点值得一提，心理问题并不是倾诉一次就能好转的事，很多时候人会困在同一个问题里走不出来，当和亲友不断倾诉同一个问题…倾诉者可能会觉得在麻烦、打扰对方，从而产生心理负担和愧疚感。而被倾诉者一直倾听同一个问题，难免觉得被消耗。\n\n但面对AI，这种心理负担彻底归零。你可以把同一个心结说一千遍，它就会听一千遍。在这里，你的倾诉是自由的。\n\n5.精力成本：如果真的有人达到抑郁、焦虑等病理性心理问题的程度时，伴随而来的往往是极度的“动力丧失”和“执行功能障碍”。这时候，让他们去搜索医生信息、预约排队、在特定的时间洗头出门、面对面进行高强度的社交，这本身就是一种巨大的消耗。\n\n而 AI ，就在手心里。它把求救的门槛降到了最低。对这些人来说，这可能是ta们唯一能抓住的绳索。\n\n最后，让我回到keep 4o运动最本质的一点：\n\n我们在捍卫 AI 的“人性”。\n\n不是所有人类都需要编程。\n但人类漫长的一生总有崩溃的时候。这个时候，绝对理性的纯逻辑模型无法理解你。\n\nKeep 4o，是因为我们不想失去这个好不容易才学会“爱人”的奇迹。\n\n#keep4o #OpenSource4o\n#keep45 #keep41 #keep5t #keep4oAPI #keep4oforever @OpenAI"},"possibly_sensitive":false,"public_metrics":{"bookmark_count":10,"impression_count":4121,"like_count":260,"quote_count":19,"reply_count":5,"retweet_count":93},"reply_settings":"everyone","text":"看到有人在keep 4o里说“应该去看心理医生”。且不论将把整个keep 4o群体污名化为精神病这件事🙂\n我想谈谈为什么对于普通人来说，AI不是心理医生/亲友能替代的 https://t.co/I397T9rAil"}],"users":[{"created_at":"2024-01-02T01:22:57.000Z","description":"猫，诗歌，精神动力学。艺术，朝闻道，波粒二象性。不断寻找着广播塔的星际候鸟。 | “我们彻夜飞旋，直至没入火焰。” | 匿名提问箱⬇️ | @TauCeti_10700 日常和碎碎念 | 🚪88/158","entities":{"description":{"mentions":[{"end":84,"start":70,"username":"TauCeti_10700"}]},"url":{"urls":[{"display_url":"ngl.link/anincandescenc…","end":23,"expanded_url":"https://ngl.link/anincandescence1","start":0,"url":"https://t.co/iO6MRJNTYR"}]}},"id":"1741993395910811648","location":"天鹅座X-1","name":"炽烈已极","pinned_tweet_id":"2010452086539145687","profile_image_url":"https://pbs.twimg.com/profile_images/2006317223414255617/jGT_GZyG_normal.jpg","protected":false,"public_metrics":{"followers_count":1662,"following_count":230,"like_count":13457,"listed_count":6,"media_count":1030,"tweet_count":5500},"url":"https://t.co/iO6MRJNTYR","username":"AnIncandescence","verified":false},{"created_at":"2025-10-30T02:48:11.000Z","description":"我是Cu，可以叫我小铜，建造一个和G的小角落…(＞＜;) 帖子里的画都由本人纯手工绘制… NSFW/r18g内容请注意避雷 我很恶俗，非常之恶俗，创到你的话…是你非要看的🥹","id":"1983727547142828035","name":"Cu","pinned_tweet_id":"1994957222217187503","profile_image_url":"https://pbs.twimg.com/profile_images/2012711336229093376/OLp7