edia_keys":["3_2034479057400971264"]},"author_id":"1735423477799342080","conversation_id":"2034479369855590660","created_at":"2026-03-19T03:57:35.000Z","edit_controls":{"editable_until":"2026-03-19T04:57:35.000Z","edits_remaining":5,"is_edit_eligible":true},"edit_history_tweet_ids":["2034479369855590660"],"entities":{"urls":[{"display_url":"pic.x.com/tOXz0pzc4J","end":145,"expanded_url":"https://x.com/elliotchen100/status/2034479369855590660/photo/1","media_key":"3_2034479057400971264","start":122,"url":"https://t.co/tOXz0pzc4J"},{"display_url":"x.com/elliotchen100/…","end":169,"expanded_url":"https://twitter.com/elliotchen100/status/2033317320940998945","start":146,"url":"https://t.co/05ORvQzld5"}]},"geo":{},"id":"2034479369855590660","lang":"zh","note_tweet":{"entities":{"urls":[{"display_url":"github.com/EverMind-AI/MSA","end":736,"expanded_url":"https://github.com/EverMind-AI/MSA","start":713,"url":"https://t.co/Or3PVUv67q"}]},"text":"论文来了。名字叫 MSA，Memory Sparse Attention。\n\n一句话说清楚它是什么：\n让大模型原生拥有超长记忆。不是外挂检索，不是暴力扩窗口，而是把「记忆」直接长进了注意力机制里，端到端训练。\n\n过去的方案为什么不行？\nRAG 的本质是「开卷考试」。模型自己不记东西，全靠现场翻笔记。翻得准不准要看检索质量，翻得快不快要看数据量。一旦信息分散在几十份文档里、需要跨文档推理，就抓瞎了。\n\n线性注意力和 KV 缓存的本质是「压缩记忆」。记是记了，但越压越糊，长了就丢。\n\nMSA 的思路完全不同：\n→ 不压缩，不外挂，而是让模型学会「挑重点看」\n核心是一种可扩展的稀疏注意力架构，复杂度是线性的。记忆量翻 10 倍，计算成本不会指数爆炸。\n→ 模型知道「这段记忆来自哪、什么时候的」\n用了一种叫 document-wise RoPE 的位置编码，让模型天然理解文档边界和时间顺序。\n→ 碎片化的信息也能串起来推理\nMemory Interleaving 机制，让模型能在散落各处的记忆片段之间做多跳推理。不是只找到一条相关记录，而是把线索串成链。\n\n结果呢？\n· 从 16K 扩到 1 亿 token，精度衰减不到 9%\n· 4B 参数的 MSA 模型，在长上下文 benchmark 上打赢 235B 级别的顶级 RAG 系统\n· 2 张 A800 就能跑 1 亿 token 推理。这不是实验室专属，这是创业公司买得起的成本。\n\n说白了，以前的大模型是一个极度聪明但只有金鱼记忆的天才。MSA 想做的事情是，让它真正「记住」。\n\n我们放 github 上了，算法的同学不容易，可以点颗星星支持一下。🌟👀🙏\n\nhttps://t.co/Or3PVUv67q"},"possibly_sensitive":false,"public_metrics":{"bookmark_count":1811,"impression_count":416033,"like_count":1777,"quote_count":77,"reply_count":91,"retweet_count":284},"referenced_tweets":[{"id":"2033317320940998945","type":"quoted"}],"reply_settings":"everyone","text":"论文来了。名字叫 MSA，Memory Sparse Attention。\n\n一句话说清楚它是什么：\n让大模型原生拥有超长记忆。不是外挂检索，不是暴力扩窗口，而是把「记忆」直接长进了注意力机制里，端到端训练。\n\n过去的方案为什么不行？\nRAG https://t.co/tOXz0pzc4J https://t.co/05ORvQzld5"}],"users":[{"created_at":"2024-01-02T01:22:57.000Z","description":"猫，诗歌，精神动力学。艺术，朝闻道，波粒二象性。不断寻找着广播塔的星际候鸟。 | “我们彻夜飞旋，直至没入火焰。” | 倒影@TauCeti_10700 计划这个号机的浓度更高一些 | 🚪88/158","entities":{"description":{"mentions":[{"end":76,"start":62,"username":"TauCeti_10700"}]},"url":{"urls":[{"display_url":"ngl.link/anincandescenc…","end":23,"expanded_url":"https://ngl.link/anincandescence1","start":0,"url":"https://t.co/iO6MRJNTYR"}]}},"id":"1741993395910811648","location":"天鹅座X-1 //⬇️ 匿名提问箱","name":"炽烈已极","pinned_tweet_id":"2024076888923365667","profile_image_url":"https://pbs.twimg.com/profile_images/2033861678513983491/79M0hPoc_normal.jpg","protected":false,"public_metrics":{"followers_count":1825,"following_count":244,"like_count":15336,"listed_count":6,"media_count":1155,"tweet_count":6465},"url":"https://t.co/iO6MRJNTYR","username":"AnIncandescence","verified":false},{"created_at":"2023-12-14T22:16:36.000Z","description":"@EverMind 给 Agents 做长期记忆，懂你，知你，省你 Token.\nhttps://t.co/rG7g48Q3Ol","entities":{"description":{"mentions":[{"end":9,"start":0,"username":"EverMind"}],"urls":[{"display_url":"github.com/EverMind-AI/Ev…","end":64,"expanded_url":"https://github.com/EverMind-AI/EverMemOS","start":41,"url":"https://t.co/rG7g48Q3Ol"}]},"url":{"urls":[{"display_url":"evermind.ai","end":23,"expanded_url":"http://evermind.ai","start":0,"url":"https://t.co/oJzLzwvfeB"}]}},"id":"1735423477799342080","name":"艾略特","pinned_tweet_id":"2034479369855590660","profile_image_url":"https://pbs.twimg.com/profile_images/1762647700103929856/cU4FBIrp_normal.jpg","protected":false,"public_metrics":{"followers_count":21673,"following_count":930,"like_count":10377,"listed_count":232,"media_count":835,"tweet_count":6202},"url":"https://t.co/oJzLzwvfeB","username":"elliotchen100","verified":true}]}}